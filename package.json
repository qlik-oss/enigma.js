{
  "name": "enigma.js",
  "version": "2.14.0",
  "description": "JavaScript library for consuming Qlik backend services",
  "author": "QlikTech International AB",
  "license": "MIT",
  "scripts": {
    "build": "rollup -c && cross-env NODE_ENV=production rollup -c",
    "test": "vitest run --coverage.enabled=true --testTimeout=5000",
    "test:watch": "vitest --testTimeout=5000",
    "test:unit": "vitest run --coverage.enabled=true --testTimeout=5000 test/unit",
    "test:unit:watch": "vitest --testTimeout=5000 test/unit",
    "test:component": "vitest run --coverage.enabled=true --testTimeout=5000 test/component",
    "test:component:watch": "vitest --testTimeout=5000 test/component",
    "test:integration": "vitest run --coverage.enabled=true --testTimeout=5000 test/integration",
    "lint": "eslint .",
    "jsdoc": "rimraf ./jsdoc && jsdoc ./src -c ./jsdoc-config.json -r -d ./jsdoc",
    "scriptappy": "jsdoc ./src -c ./jsdoc-config.json -r ./package.json -X | scriptappy-from-jsdoc -c spec.config.js",
    "preversion": "npm run test && npm run test:integration",
    "version": "npm run build && npm run scriptappy"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/qlik-oss/enigma.js"
  },
  "files": [
    "/enigma.js",
    "/enigma.js.map",
    "/enigma.min.js",
    "/enigma.min.js.map",
    "/enigma.d.ts",
    "/sense-utilities.js",
    "/sense-utilities.js.map",
    "/sense-utilities.min.js",
    "/sense-utilities.min.js.map",
    "/sense-utilities.d.ts",
    "/error-codes.js",
    "/error-codes.d.ts",
    "/schemas"
  ],
  "main": "enigma.js",
  "devDependencies": {
    "@vitest/coverage-v8": "3.2.4",
    "@babel/core": "7.29.0",
    "@babel/plugin-transform-modules-commonjs": "7.28.6",
    "@babel/preset-env": "7.29.2",
    "@joseph184/rollup-plugin-node-builtins": "2.1.4",
    "chai": "4.5.0",
    "chai-as-promised": "7.1.2",
    "chai-subset": "1.6.0",
    "babel-plugin-istanbul": "7.0.1",
    "coveralls": "3.1.1",
    "cross-env": "10.1.0",
    "dotenv": "16.6.1",
    "eslint": "8.57.1",
    "eslint-config-airbnb-base": "15.0.0",
    "eslint-plugin-import": "2.32.0",
    "extend": "3.0.2",
    "jsdoc": "4.0.5",
    "node-event-emitter": "0.0.1",
    "querystring": "0.2.1",
    "rimraf": "6.1.3",
    "rollup": "2.80.0",
    "@rollup/plugin-babel": "5.0.0",
    "rollup-plugin-commonjs": "10.1.0",
    "rollup-plugin-filesize": "10.0.0",
    "rollup-plugin-license": "3.7.0",
    "rollup-plugin-node-globals": "1.4.0",
    "rollup-plugin-node-resolve": "5.2.0",
    "rollup-plugin-terser": "7.0.2",
    "scriptappy-from-jsdoc": "0.7.0",
    "sinon": "17.0.1",
    "sinon-chai": "3.7.0",
    "vitest": "3.2.4",
    "ws": "8.20.0"
  }
}
